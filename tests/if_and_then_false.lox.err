== code ==
0000    1 OP_TRUE
0001    | OP_JUMP_IF_FALSE    1 -> 6
0004    | OP_POP
0005    | OP_FALSE
0006    | OP_JUMP_IF_FALSE    6 -> 16
0009    | OP_POP
0010    2 OP_CONSTANT         0 'Hello'
0012    | OP_PRINT
0013    3 OP_JUMP            13 -> 17
0016    | OP_POP
0017    5 OP_CONSTANT         1 'World'
0019    | OP_PRINT
0020    6 OP_RETURN
