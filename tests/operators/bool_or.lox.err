== is ==
0000    1 OP_GET_GLOBAL       0 'typeof'
0002    | OP_GET_LOCAL        1
0004    | OP_CALL             1
0006    | OP_GET_LOCAL        2
0008    | OP_EQUAL
0009    | OP_RETURN
== is_function ==
0000    3 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'function'
0006    | OP_CALL             2
0008    | OP_RETURN
== is_number ==
0000    5 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'number'
0006    | OP_CALL             2
0008    | OP_RETURN
== is_string ==
0000    7 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'string'
0006    | OP_CALL             2
0008    | OP_RETURN
== is_bool ==
0000    9 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'bool'
0006    | OP_CALL             2
0008    | OP_RETURN
== is_nil ==
0000   11 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'nil'
0006    | OP_CALL             2
0008    | OP_RETURN
== is_empty ==
0000   13 OP_GET_GLOBAL       0 'is_string'
0002    | OP_GET_LOCAL        1
0004    | OP_CALL             1
0006    | OP_JUMP_IF_FALSE    6 -> 19
0009    | OP_POP
0010    | OP_GET_GLOBAL       1 'len'
0012    | OP_GET_LOCAL        1
0014    | OP_CALL             1
0016    | OP_CONSTANT         2 '0.000000'
0018    | OP_EQUAL
0019    | OP_RETURN
== <script> ==
0000    1 OP_CLOSURE          1 <fn is>
0002    | OP_DEFINE_GLOBAL    0 'is'
0004    3 OP_CLOSURE          3 <fn is_function>
0006    | OP_DEFINE_GLOBAL    2 'is_function'
0008    5 OP_CLOSURE          5 <fn is_number>
0010    | OP_DEFINE_GLOBAL    4 'is_number'
0012    7 OP_CLOSURE          7 <fn is_string>
0014    | OP_DEFINE_GLOBAL    6 'is_string'
0016    9 OP_CLOSURE          9 <fn is_bool>
0018    | OP_DEFINE_GLOBAL    8 'is_bool'
0020   11 OP_CLOSURE         11 <fn is_nil>
0022    | OP_DEFINE_GLOBAL   10 'is_nil'
0024   13 OP_CLOSURE         13 <fn is_empty>
0026    | OP_DEFINE_GLOBAL   12 'is_empty'
0028   14 OP_NIL
0029    | OP_RETURN
== should_not_call ==
0000   14 OP_CONSTANT         0 'Should not print'
0002    | OP_PRINT
0003   15 OP_NIL
0004    | OP_RETURN
== <script> ==
0000    1 OP_FALSE
0001    | OP_JUMP_IF_FALSE    1 -> 7
0004    | OP_JUMP             4 -> 9
0007    | OP_POP
0008    | OP_TRUE
0009    | OP_PRINT
0010    2 OP_FALSE
0011    | OP_JUMP_IF_FALSE   11 -> 17
0014    | OP_JUMP            14 -> 19
0017    | OP_POP
0018    | OP_TRUE
0019    | OP_PRINT
0020    4 OP_TRUE
0021    | OP_JUMP_IF_FALSE   21 -> 27
0024    | OP_JUMP            24 -> 29
0027    | OP_POP
0028    | OP_FALSE
0029    | OP_PRINT
0030    5 OP_TRUE
0031    | OP_JUMP_IF_FALSE   31 -> 37
0034    | OP_JUMP            34 -> 39
0037    | OP_POP
0038    | OP_FALSE
0039    | OP_PRINT
0040    7 OP_TRUE
0041    | OP_JUMP_IF_FALSE   41 -> 47
0044    | OP_JUMP            44 -> 49
0047    | OP_POP
0048    | OP_TRUE
0049    | OP_PRINT
0050    8 OP_TRUE
0051    | OP_JUMP_IF_FALSE   51 -> 57
0054    | OP_JUMP            54 -> 59
0057    | OP_POP
0058    | OP_TRUE
0059    | OP_PRINT
0060   10 OP_FALSE
0061    | OP_JUMP_IF_FALSE   61 -> 67
0064    | OP_JUMP            64 -> 69
0067    | OP_POP
0068    | OP_FALSE
0069    | OP_PRINT
0070   11 OP_FALSE
0071    | OP_JUMP_IF_FALSE   71 -> 77
0074    | OP_JUMP            74 -> 79
0077    | OP_POP
0078    | OP_FALSE
0079    | OP_PRINT
0080   15 OP_CLOSURE          1 <fn should_not_call>
0082    | OP_DEFINE_GLOBAL    0 'should_not_call'
0084   17 OP_TRUE
0085    | OP_JUMP_IF_FALSE   85 -> 91
0088    | OP_JUMP            88 -> 96
0091    | OP_POP
0092    | OP_GET_GLOBAL       2 'should_not_call'
0094    | OP_CALL             0
0096    | OP_PRINT
0097   18 OP_NIL
0098    | OP_RETURN
