== sum ==
0000    2 OP_GET_LOCAL        1
0002    | OP_GET_LOCAL        2
0004    | OP_ADD
0005    | OP_RETURN
0006    3 OP_NIL
0007    | OP_RETURN
== <script> ==
0000    3 OP_CONSTANT         1 '<fn sum>'
0002    | OP_DEFINE_GLOBAL    0 'sum'
0004    5 OP_GET_GLOBAL       2 'sum'
0006    | OP_CONSTANT         3 '1'
0008    | OP_CONSTANT         4 '2'
0010    | OP_CALL             2
0012    | OP_PRINT
0013    | OP_NIL
0014    | OP_RETURN
