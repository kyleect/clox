== is_empty ==
0000   26 OP_GET_GLOBAL       0 'is_string'
0002    | OP_GET_LOCAL        1
0004    | OP_CALL             1
0006    | OP_JUMP_IF_FALSE    6 -> 19
0009    | OP_POP
0010    | OP_GET_GLOBAL       1 'len'
0012    | OP_GET_LOCAL        1
0014    | OP_CALL             1
0016    | OP_CONSTANT         2 '0.000000'
0018    | OP_EQUAL
0019    | OP_RETURN
0020   27 OP_NIL
0021    | OP_RETURN
== <script> ==
