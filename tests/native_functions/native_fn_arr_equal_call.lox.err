== is ==
0000    2 OP_GET_GLOBAL       0 'typeof'
0002    | OP_GET_LOCAL        1
0004    | OP_CALL             1
0006    | OP_GET_LOCAL        2
0008    | OP_EQUAL
0009    | OP_RETURN
0010    3 OP_NIL
0011    | OP_RETURN
== is_function ==
0000    6 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'function'
0006    | OP_CALL             2
0008    | OP_RETURN
0009    7 OP_NIL
0010    | OP_RETURN
