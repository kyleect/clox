== is ==
0000    1 OP_GET_GLOBAL       0 'typeof'
0002    | OP_GET_LOCAL        1
0004    | OP_CALL             1
0006    | OP_GET_LOCAL        2
0008    | OP_EQUAL
0009    | OP_RETURN
== is_function ==
0000    3 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'function'
0006    | OP_CALL             2
0008    | OP_RETURN
== is_number ==
0000    5 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'number'
0006    | OP_CALL             2
0008    | OP_RETURN
== is_string ==
0000    7 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'string'
0006    | OP_CALL             2
0008    | OP_RETURN
== is_bool ==
0000    9 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'bool'
0006    | OP_CALL             2
0008    | OP_RETURN
== is_nil ==
0000   11 OP_GET_GLOBAL       0 'is'
0002    | OP_GET_LOCAL        1
0004    | OP_CONSTANT         1 'nil'
0006    | OP_CALL             2
0008    | OP_RETURN
== is_empty ==
0000   13 OP_GET_GLOBAL       0 'is_string'
0002    | OP_GET_LOCAL        1
0004    | OP_CALL             1
0006    | OP_JUMP_IF_FALSE    6 -> 19
0009    | OP_POP
0010    | OP_GET_GLOBAL       1 'len'
0012    | OP_GET_LOCAL        1
0014    | OP_CALL             1
0016    | OP_CONSTANT         2 '0.000000'
0018    | OP_EQUAL
0019    | OP_RETURN
== <script> ==
0000    1 OP_CLOSURE          1 <fn is>
0002    | OP_DEFINE_GLOBAL    0 'is'
0004    3 OP_CLOSURE          3 <fn is_function>
0006    | OP_DEFINE_GLOBAL    2 'is_function'
0008    5 OP_CLOSURE          5 <fn is_number>
0010    | OP_DEFINE_GLOBAL    4 'is_number'
0012    7 OP_CLOSURE          7 <fn is_string>
0014    | OP_DEFINE_GLOBAL    6 'is_string'
0016    9 OP_CLOSURE          9 <fn is_bool>
0018    | OP_DEFINE_GLOBAL    8 'is_bool'
0020   11 OP_CLOSURE         11 <fn is_nil>
0022    | OP_DEFINE_GLOBAL   10 'is_nil'
0024   13 OP_CLOSURE         13 <fn is_empty>
0026    | OP_DEFINE_GLOBAL   12 'is_empty'
0028   14 OP_NIL
0029    | OP_RETURN
== <script> ==
0000    1 OP_GET_GLOBAL       0 'argc'
0002    | OP_CALL             0
0004    | OP_PRINT
0005    2 OP_GET_GLOBAL       1 'argv'
0007    | OP_CONSTANT         2 '0.000000'
0009    | OP_CALL             1
0011    | OP_PRINT
0012    3 OP_GET_GLOBAL       3 'argv'
0014    | OP_CONSTANT         4 '1.000000'
0016    | OP_CALL             1
0018    | OP_PRINT
0019    4 OP_GET_GLOBAL       5 'argv'
0021    | OP_CONSTANT         6 '2.000000'
0023    | OP_CALL             1
0025    | OP_PRINT
0026    5 OP_GET_GLOBAL       7 'argv'
0028    | OP_CONSTANT         8 '3.000000'
0030    | OP_CALL             1
0032    | OP_PRINT
0033    6 OP_GET_GLOBAL       9 'argv'
0035    | OP_CONSTANT        10 '4.000000'
0037    | OP_CALL             1
0039    | OP_PRINT
0040    7 OP_GET_GLOBAL      11 'argv'
0042    | OP_CONSTANT        12 '99.000000'
0044    | OP_CALL             1
0046    | OP_PRINT
0047    | OP_NIL
0048    | OP_RETURN
