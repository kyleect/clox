fun is(value, type) = typeof(value) == type;

fun is_function(value) = is(value, "function");

fun is_number(value) = is(value, "number");

fun is_string(value) = is(value, "string");

fun is_bool(value) = is(value, "bool");

fun is_nil(value) = is(value, "nil");

fun is_empty(value) = is_string(value) and len(value) == 0;
