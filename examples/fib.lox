fun fib(n) {
  if (n < 2) return n;
  return fib(n - 2) + fib(n - 1);
}

print "Fibonacci";

var argIndex = 4;
var arg = argv(argIndex);

if (arg == nil) {
  arg = prompt("n: ");
}

var n = parseNumber(arg);

print n;
print "";

var start = clock();

print "Result:";
print "";
print fib(n);

print "";

print "Time Taken:";
print clock() - start;