{
  "scopeName": "source.clox",
  "patterns": [
    {
      "name": "keyword.control.clox",
      "match": "\\b(if|else|for|while|fun|return|var|print|true|false|nil|class|this)\\b"
    },
    {
      "name": "entity.name.function.native.clox",
      "match": "\\b(clock|len|argv|argc|typeof|rand|rand01|randBetween|ceil|readFileToString|writeStringToFile|fileExists|getenv|setenv|__version__|exit|instanceOf|prompt|stdin|parseNumber|numberToString|arrPush|arrPop|arrInsert|arrRemove|arrClear|arrContains)\\b"
    },
    {
      "name": "entity.name.function.stdlib.clox",
      "match": "\\b(is|is_number|is_string|is_nil|is_function|is_bool|is_empty)\\b"
    },
    {
      "name": "entity.name.function.method.clox",
      "match": "(?<=[A-Za-z_][A-Za-z0-9_]*\\s*\\.\\s*)\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
    },
    {
      "name": "variable.name.property.clox",
      "match": "(?<=[A-Za-z_][A-Za-z0-9_]*\\s*\\.\\s*)\\b[A-Za-z_][A-Za-z0-9_]*\\b(?!\\s*\\()"
    },
    {
      "name": "string.quoted.double.clox",
      "match": "\".*?\""
    },
    {
      "name": "constant.numeric.clox",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    {
      "name": "comment.line.double-slash.clox",
      "match": "//.*$"
    }
  ]
}
